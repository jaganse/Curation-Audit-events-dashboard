          "rawSql": "SELECT COUNT(*) FROM audit_events WHERE is_dry_run = false AND $__timeFilter(created_at) AND ('$package_type' = ANY(ARRAY['', 'All']) OR package_type = '$package_type') AND ('$repository' = ANY(ARRAY['', 'All']) OR curated_repository_name = '$repository') AND action = 'blocked'",
