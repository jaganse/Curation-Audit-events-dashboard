  "panels": [
    {
      "type": "stat",
      "title": "Total Dry-Run Events",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT COUNT(*) FROM audit_events WHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))  ",
          "format": "table",
          "refId": "A"
        }
      ]
    },
