            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT COUNT(*) FROM audit_events WHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))   AND action = 'approved'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Unique Packages",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT COUNT(DISTINCT package_name) FROM audit_events WHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))  ",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Simulated Blocked vs Approved Over Time",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "approved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "blocked"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT\n  $__timeGroupAlias(created_at,'1d') AS time,\n  COUNT(*) AS approved\nFROM audit_events\nWHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))   AND action = 'approved'\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT\n  $__timeGroupAlias(created_at,'1d') AS time,\n  COUNT(*) AS blocked\nFROM audit_events\nWHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))   AND action = 'blocked'\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "type": "table",
      "title": "Top Would-Be Blocked Packages",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT\n  package_name,\n  package_type,\n  COUNT(*) AS block_count\nFROM audit_events\nWHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))  AND action = 'blocked'\nGROUP BY package_name, package_type\nORDER BY block_count DESC\nLIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Dry-Run Policy Breakdown",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT\n  ep.policy_name,\n  COUNT(*) AS triggered_count\nFROM audit_events ae\nJOIN event_policies ep ON ae.id = ep.event_id\nWHERE ae.is_dry_run = true AND $__timeFilter(ae.created_at)\nAND ('$package_type' = 'All' OR ae.package_type IN ($package_type))\nGROUP BY ep.policy_name\nORDER BY triggered_count DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "User Activity",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT\n  username,\n  COUNT(*) AS total_events,\n  SUM(CASE WHEN action = 'blocked' THEN 1 ELSE 0 END) AS blocked_count,\n  SUM(CASE WHEN action = 'approved' THEN 1 ELSE 0 END) AS approved_count\nFROM audit_events\nWHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))  \nGROUP BY username\nORDER BY total_events DESC\nLIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Package Type Distribution",
      "datasource": {
        "type": "postgres",
        "uid": "curation_pg"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "curation_pg"
          },
          "rawSql": "SELECT\n  package_type,\n  COUNT(*) AS count\nFROM audit_events\nWHERE is_dry_run = true AND $__timeFilter(created_at) AND ('$package_type' = 'All' OR package_type IN ($package_type))  \nGROUP BY package_type\nORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
