# Your JFrog platform base URL (no trailing slash).
# Example: https://myorg.jfrog.io
JFROG_URL=https://myinstance.jfrog.io

# A JFrog Identity Token or Access Token with Curation read scope.
# Generate one at: Platform → User Management → Access Tokens
JFROG_TOKEN=your-access-token-here

# Days of history to load on each ETL run.
# Use 30–365 for the initial historical backfill, then reduce to 2 for daily cron runs.
LOOKBACK_DAYS=30

# Grafana admin UI password. Change this before exposing on a shared network.
GRAFANA_ADMIN_PASSWORD=admin
